# ── Trading212 ──────────────────────────────────────────────────────────────
# Get your API key: Settings → API Key in Trading212 app
T212_API_KEY=your_t212_api_key_here
T212_API_SECRET=your_t212_api_secret_here
# "demo" uses Paper Trading  |  "live" uses real money (USE WITH CAUTION)
T212_ENV=demo
# "invest" (default) = Invest/ISA account — long-only
# "cfd"              = CFD account — supports long AND short positions
T212_ACCOUNT_TYPE=invest

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Bot Behaviour ────────────────────────────────────────────────────────────
BOT_ENABLED=true
SKIP_MARKET_HOURS_CHECK=false   # Set to true to run outside NYSE hours (testing only)
TRADE_INTERVAL_SECONDS=300
MAX_POSITION_SIZE_PCT=0.05
MAX_OPEN_POSITIONS=10
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# ── Earnings calendar ─────────────────────────────────────────────────────
# Avoid trading around earnings announcements
EARNINGS_DAYS_BEFORE=2
EARNINGS_DAYS_AFTER=1
BLOCK_NEW_POSITIONS_ON_EARNINGS=true
FINNHUB_API_KEY=           # get free key at finnhub.io

# ── News feed ─────────────────────────────────────────────────────────────────
# Injects recent headlines into Claude prompt for fundamental context
# FINNHUB_API_KEY is reused (set above) — no extra key needed for Finnhub news
NEWS_API_KEY=              # optional fallback: newsapi.org (free: 100 req/day)
NEWS_LOOKBACK_DAYS=3
NEWS_MAX_HEADLINES_PER_TICKER=5
NEWS_CACHE_TTL_SECONDS=900

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8888
SECRET_KEY=change-me-in-production
