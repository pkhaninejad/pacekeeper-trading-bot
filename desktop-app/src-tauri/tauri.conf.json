{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Trade Bot",
  "version": "0.1.0",
  "identifier": "com.claudetradebot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Trade Bot",
        "width": 980,
        "height": 760,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "icon": []
  }
}
