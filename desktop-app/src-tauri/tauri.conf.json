{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pacekeeper",
  "version": "1.1.2",
  "identifier": "de.wallstrdev.pacekeeper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pacekeeper",
        "width": 980,
        "height": 760,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
