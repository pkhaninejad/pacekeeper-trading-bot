{
  "active": "azure-model-router",
  "providers": {
    "claude-sonnet": {
      "description": "Anthropic Claude Sonnet via direct API",
      "litellm_model": "claude-sonnet-4-6",
      "api_key": "$ANTHROPIC_API_KEY",
      "temperature": 0.3,
      "max_tokens": 2048
    },
    "azure-model-router": {
      "description": "Azure OpenAI — model-router deployment",
      "provider_type": "azure_openai",
      "litellm_model": "azure/model-router",
      "api_base": "https://smart-match-resource.openai.azure.com/",
      "api_key": "$AZURE_AI_KEY",
      "api_version": "2024-12-01-preview",
      "temperature": 0.7,
      "max_tokens": 2048
    },
    "azure-gpt5-nano": {
      "description": "Azure AI Foundry — gpt-5-nano deployment",
      "litellm_model": "openai/gpt-5-nano",
      "api_base": "https://smart-match-resource.services.ai.azure.com/api/projects/smart-match",
      "api_key": "$AZURE_AI_KEY",
      "api_version": "2025-01-01-preview",
      "temperature": 1,
      "max_tokens": 2048
    }
  }
}
