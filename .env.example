# ── Trading212 ──────────────────────────────────────────────────────────────
# Get your API key: Settings → API Key in Trading212 app
T212_API_KEY=your_t212_api_key_here
T212_API_SECRET=your_t212_api_secret_here
# "demo" uses Paper Trading  |  "live" uses real money (USE WITH CAUTION)
T212_ENV=demo

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Bot Behaviour ────────────────────────────────────────────────────────────
BOT_ENABLED=true
TRADE_INTERVAL_SECONDS=300
MAX_POSITION_SIZE_PCT=0.05
MAX_OPEN_POSITIONS=10
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
SECRET_KEY=change-me-in-production
